@page "/compte"
@inject ApiClient Api
@inject SessionUtilisateur Session

<h1>Compte &amp; connexion</h1>
<p class="muet">
    Authentification par jeton JWT (ADR 0008) : votre identité est portée par le jeton, jamais
    saisie dans les formulaires d'action. Inscrivez-vous ou connectez-vous pour obtenir un jeton.
</p>

@if (Session.EstConnecte)
{
    <div class="carte">
        <h3>Session active</h3>
        <p>
            <span class="chip">@Session.Email
                <span class="badge-role role-@Session.Role">@Session.Role</span>
            </span>
        </p>
        <p class="muet">Identifiant : <code>@Session.UtilisateurId</code></p>
        <button class="secondaire" @onclick="Deconnecter">Se déconnecter</button>
    </div>
}

<div class="grille">
    <div class="carte">
        <h3>S'inscrire</h3>
        <label>Email</label>
        <input @bind="_emailInscription" placeholder="prenom.nom@exemple.fr" />
        <label>Mot de passe (8 caractères min.)</label>
        <input type="password" @bind="_mdpInscription" />
        <label>Rôle</label>
        <select @bind="_role">
            <option value="@RoleUtilisateur.Candidat">Candidat</option>
            <option value="@RoleUtilisateur.Entreprise">Entreprise</option>
            <option value="@RoleUtilisateur.Administrateur">Administrateur</option>
        </select>
        <br /><br />
        <button @onclick="Inscrire" disabled="@_occupe">S'inscrire et se connecter</button>
    </div>

    <div class="carte">
        <h3>Se connecter</h3>
        <label>Email</label>
        <input @bind="_emailConnexion" placeholder="votre email" />
        <label>Mot de passe</label>
        <input type="password" @bind="_mdpConnexion" />
        <br /><br />
        <button class="secondaire" @onclick="Connecter" disabled="@_occupe">Se connecter</button>
    </div>
</div>

@if (_message is not null)
{
    <div class="alerte @_classe">@_message</div>
}

@code {
    private string _emailInscription = "", _mdpInscription = "";
    private RoleUtilisateur _role = RoleUtilisateur.Candidat;
    private string _emailConnexion = "", _mdpConnexion = "";

    private bool _occupe;
    private string? _message;
    private string _classe = "info";

    private async Task Inscrire()
    {
        if (string.IsNullOrWhiteSpace(_emailInscription)) { Avertir("Saisissez un email.", "erreur"); return; }
        _occupe = true;
        try
        {
            var s = await Api.InscrireAsync(_emailInscription.Trim(), _mdpInscription, _role);
            OuvrirSession(s);
            Avertir($"Compte créé — connecté en tant que {s.Role}.", "ok");
        }
        catch (ApiException ex) { Avertir(ex.Message, "erreur"); }
        finally { _occupe = false; }
    }

    private async Task Connecter()
    {
        _occupe = true;
        try
        {
            var s = await Api.ConnecterAsync(_emailConnexion.Trim(), _mdpConnexion);
            OuvrirSession(s);
            Avertir($"Connecté en tant que {s.Role}.", "ok");
        }
        catch (ApiException ex) { Avertir(ex.Message, "erreur"); }
        finally { _occupe = false; }
    }

    private void OuvrirSession(SessionReponse s)
    {
        var role = Enum.Parse<RoleUtilisateur>(s.Role);
        Session.Ouvrir(s.Id, s.Email, role, s.Jeton);
        _mdpInscription = _mdpConnexion = "";
    }

    private void Deconnecter()
    {
        Session.Fermer();
        Avertir("Déconnecté.", "info");
    }

    private void Avertir(string message, string classe)
    {
        _message = message;
        _classe = classe;
    }
}
